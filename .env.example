# Required bot runtime
BOT_1_TOKEN=your_discord_bot_token
BOT_1_CLIENT_ID=your_discord_application_id

# Optional display and tier metadata
BOT_1_NAME=OmniFM DJ
BOT_1_TIER=free
COMMANDER_BOT_INDEX=1

# Local web/API defaults
WEB_PORT=8081
WEB_INTERNAL_PORT=8080
PUBLIC_WEB_URL=http://localhost:8081

# Optional public legal page details
LEGAL_PROVIDER_NAME=OmniFM Example Operator
LEGAL_STREET_ADDRESS=Example Street 1
LEGAL_POSTAL_CODE=1010
LEGAL_CITY=Vienna
LEGAL_COUNTRY=Austria
LEGAL_EMAIL=legal@example.com
LEGAL_WEBSITE=http://localhost:8081
PRIVACY_CONTACT_EMAIL=privacy@example.com
PRIVACY_HOSTING_PROVIDER=Example Hosting
PRIVACY_HOSTING_LOCATION=EU / Austria
TERMS_CONTACT_EMAIL=terms@example.com
TERMS_SUPPORT_URL=http://localhost:8081/terms
TERMS_EFFECTIVE_DATE=2026-03-11
TERMS_GOVERNING_LAW=Law of the Republic of Austria
TERMS_CUSTOM_NOTE=

# Optional dashboard OAuth for local testing
DISCORD_CLIENT_ID=your_dashboard_client_id
DISCORD_CLIENT_SECRET=your_dashboard_client_secret
DISCORD_REDIRECT_URI=http://localhost:8081/api/auth/discord/callback

# Optional local admin/dev helpers
API_ADMIN_TOKEN=change-me
MONGO_ENABLED=0

# Optional DiscordBotList / discordbotlist.com integration
DISCORDBOTLIST_ENABLED=0
DISCORDBOTLIST_TOKEN=
DISCORDBOTLIST_BOT_ID=
DISCORDBOTLIST_SLUG=
DISCORDBOTLIST_WEBHOOK_SECRET=
DISCORDBOTLIST_STATS_SCOPE=aggregate
DISCORDBOTLIST_COMMANDS_SYNC_MS=21600000
DISCORDBOTLIST_STATS_SYNC_MS=1800000
DISCORDBOTLIST_VOTE_SYNC_MS=1800000

# Optional discord.bots.gg stats integration
BOTSGG_ENABLED=0
BOTSGG_TOKEN=
BOTSGG_BOT_ID=
BOTSGG_STATS_SCOPE=aggregate
BOTSGG_STARTUP_DELAY_MS=15000
BOTSGG_STATS_SYNC_MS=1800000

# Optional Top.gg project, stats, vote, and webhook integration
TOPGG_ENABLED=0
TOPGG_TOKEN=
TOPGG_BOT_ID=
TOPGG_WEBHOOK_SECRET=
TOPGG_STATS_SCOPE=aggregate
TOPGG_STARTUP_DELAY_MS=15000
TOPGG_PROJECT_SYNC_MS=21600000
TOPGG_COMMANDS_SYNC_MS=21600000
TOPGG_STATS_SYNC_MS=1800000
TOPGG_VOTE_SYNC_MS=1800000
TOPGG_VOTE_SYNC_START_DAYS=30

# Optional runtime safety and logging
PREMIUM_GUILD_ACCESS_MODE=restrict
VOICE_CHANNEL_STATUS_ENABLED=1
VOICE_CHANNEL_STATUS_TEMPLATE=🔊 | 24/7 {station}
VOICE_CHANNEL_STATUS_REFRESH_MS=900000
VOICE_STATE_RECONCILE_ENABLED=1
VOICE_STATE_RECONCILE_MS=30000
STREAM_RESTART_BASE_MS=1000
STREAM_RESTART_MAX_MS=120000
STREAM_ERROR_COOLDOWN_THRESHOLD=8
STREAM_ERROR_COOLDOWN_MS=60000
VOICE_RECONNECT_MAX_MS=120000
VOICE_RECONNECT_CIRCUIT_BREAKER_ATTEMPTS=30
VOICE_RECONNECT_CIRCUIT_BREAKER_MS=900000
VOICE_TRANSIENT_RECHECK_MS=5000
VOICE_STATE_MISSING_CONFIRMATIONS=2
VOICE_RECONNECT_RESOURCE_CONFIRMATIONS=3
DNS_LOOKUP_RETRY_COUNT=3
DNS_LOOKUP_RETRY_DELAY_MS=750
DNS_LOOKUP_CACHE_TTL_MS=600000
DNS_LOOKUP_STALE_TTL_MS=3600000
LOG_MAX_MB=5
LOG_MAX_FILES=30
LOG_MAX_DAYS=14
LOGS_DIR=logs
