From 2d264a2191fd2c1944e1d0f3ad0c5cc730501259 Mon Sep 17 00:00:00 2001
From: emergent-agent-e1 <github@emergent.sh>
Date: Tue, 3 Mar 2026 09:49:36 +0000
Subject: [PATCH] fix: DAVE E2EE Protokoll Support + 7 weitere Bugfixes

BREAKING: Discord erzwingt seit 01.03.2026 DAVE E2EE fuer Voice.

Kritische Fixes:
- Dockerfile: node:20 -> node:22 + libsodium-dev
- package.json: @snazzah/davey, sodium-native, libsodium-wrappers
- index.js: Voice-Dependency-Report beim Start
- runtime.js: ephemeral->MessageFlags (133x), album undefined fix,
  Voice-Timeout 20s->30s, Auto-Reconnect bei Voice-Timeout,
  Triple setEmoji fix
- guild-language-store.js: Auto-Repair bei korrupter JSON
- docker-entrypoint.sh: JSON-Validierung beim Container-Start
---
 Dockerfile                  |   5 +-
 docker-entrypoint.sh        |   9 +
 package.json                |   3 +
 src/bot/runtime.js          | 317 +++++++++++++++++++-----------------
 src/guild-language-store.js |  27 ++-
 src/index.js                |   9 +
 6 files changed, 222 insertions(+), 148 deletions(-)

diff --git a/Dockerfile b/Dockerfile
index a394edf..3e99aa1 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -1,6 +1,6 @@
 # escape=\
 
-FROM node:20-slim AS frontend-builder
+FROM node:22-slim AS frontend-builder
 
 WORKDIR /frontend
 
@@ -10,7 +10,7 @@ RUN npm install
 COPY frontend/ ./
 RUN npm run build
 
-FROM node:20-slim
+FROM node:22-slim
 
 RUN set -eux; \
   apt-get update; \
@@ -24,6 +24,7 @@ RUN set -eux; \
     ca-certificates \
     libopus0 \
     libopus-dev \
+    libsodium-dev \
     python3 \
     make \
     g++ \
diff --git a/docker-entrypoint.sh b/docker-entrypoint.sh
index 0e98265..cc2de6d 100755
--- a/docker-entrypoint.sh
+++ b/docker-entrypoint.sh
@@ -33,6 +33,15 @@ init_json_file() {
   if [ -f "$filepath" ] && [ ! -s "$filepath" ]; then
     echo '{}' > "$filepath" 2>/dev/null || true
   fi
+
+  # Validate JSON content
+  if [ -f "$filepath" ] && [ -s "$filepath" ]; then
+    if ! node -e "JSON.parse(require('fs').readFileSync('$filepath','utf8'))" 2>/dev/null; then
+      echo "[WARN] $filename enthaelt ungueltiges JSON. Erstelle Backup und initialisiere neu."
+      cp "$filepath" "${filepath}.corrupt-$(date +%s)" 2>/dev/null || true
+      echo '{}' > "$filepath" 2>/dev/null || true
+    fi
+  fi
 }
 
 init_json_file "/app/bot-state.json"
